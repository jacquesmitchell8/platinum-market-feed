# Copy this file to .env.seed and paste REAL values from:
# Netlify → Site configuration → Environment variables
#
# NEVER commit .env.seed to git.

SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=paste-from-netlify-here
METALS_DEV_API_KEY=paste-from-netlify-here
COINGECKO_API_KEY=paste-from-netlify-here
# Free JSE producer history — https://twelvedata.com/pricing (takes ~10s to sign up)
TWELVE_DATA_API_KEY=paste-twelve-data-key-here
